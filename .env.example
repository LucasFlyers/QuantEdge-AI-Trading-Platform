# ─── QuantEdge AI Trading Intelligence Platform ───────────────────────────────
# Environment Variable Reference
# Copy to .env for local development. Set directly in Railway dashboard for prod.
#
# REQUIRED variables are marked [REQUIRED] — platform will not start without them.
# OPTIONAL variables have sensible defaults.
# ─────────────────────────────────────────────────────────────────────────────


# ── Platform ──────────────────────────────────────────────────────────────────

# Environment tag (development | staging | production)
PLATFORM_ENV=production

# Log verbosity (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# API server bind address — leave as 0.0.0.0 for Railway
API_HOST=0.0.0.0

# Railway injects $PORT automatically. Set manually for local dev.
PORT=8000

# Number of Uvicorn workers (Railway free tier: 1–2 recommended)
API_WORKERS=2


# ── Database — Neon PostgreSQL [REQUIRED] ─────────────────────────────────────
#
# 1. Create a free project at https://neon.tech
# 2. Go to your project → Connection Details
# 3. Select "Pooled connection" (uses PgBouncer — required for this app)
# 4. Copy the connection string and paste below
#
# Format: postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require
#
# The app runs schema migrations automatically on startup — no manual SQL needed.

DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require


# ── Redis [REQUIRED for caching & rate limiting] ──────────────────────────────
#
# Option A — Railway Redis plugin (recommended):
#   Add the Redis plugin in your Railway project.
#   Railway auto-injects REDIS_URL. Use REDIS_URL directly if preferred.
#
# Option B — Upstash Redis (free serverless option):
#   https://upstash.com → create database → copy Redis URL
#
# Option C — Set individual vars:

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:port/0  # Alternative: single URL


# ── Telegram Bot [REQUIRED for alerts] ───────────────────────────────────────
#
# 1. Message @BotFather on Telegram
# 2. /newbot → follow prompts → copy bot token
# 3. Add the bot to your channel/group
# 4. Get chat ID: message @userinfobot or check getUpdates API
#
# For a private channel: chat_id starts with -100...
# For a group:           chat_id starts with -...
# For a direct chat:     chat_id is your numeric user ID

TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890

# Optional: separate chat for high-priority alerts only
TELEGRAM_ALERT_CHAT_ID=


# ── Discord [OPTIONAL] ────────────────────────────────────────────────────────
#
# Create a webhook in your Discord server:
#   Server Settings → Integrations → Webhooks → New Webhook → Copy URL

DISCORD_WEBHOOK_URL=


# ── On-Chain / Whale Tracking [OPTIONAL — Phase 5] ───────────────────────────
#
# Etherscan API key for Ethereum transaction monitoring
# Free key: https://etherscan.io/apis

ETHERSCAN_API_KEY=

# Blockchain.com API key for Bitcoin monitoring
BLOCKCHAIN_API_KEY=


# ── Exchange API Keys [OPTIONAL — needed for order execution only] ─────────
# Signal generation uses public WebSocket feeds — no API keys needed.
# These are only needed if you add order execution in a future phase.

BINANCE_API_KEY=
BINANCE_API_SECRET=

COINBASE_API_KEY=
COINBASE_API_SECRET=

KRAKEN_API_KEY=
KRAKEN_API_SECRET=


# ── Signal Thresholds [OPTIONAL — tune live behavior] ────────────────────────

# Minimum net profit in basis points to emit an arbitrage signal (default: 20)
ARB_MIN_PROFIT_BPS=20

# Minimum confidence score 0.0–1.0 (default: 0.65)
ARB_MIN_CONFIDENCE=0.65

# Mention surge multiplier to trigger sentiment signal (default: 2.0 = +100%)
SENTIMENT_SURGE_MULTIPLIER=2.0
